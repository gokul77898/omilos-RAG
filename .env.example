# Database (port 5433 — tách biệt khỏi SlideAgentPro)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/omilosrag

# ChromaDB (port 8002 — tách biệt khỏi SlideAgentPro)
CHROMA_HOST=localhost
CHROMA_PORT=8002

# ===========================================
# LLM Provider: "gemini" | "ollama"
# Chuyển provider: comment block này, uncomment block kia
# ===========================================

# --- Gemini (active) ---
LLM_PROVIDER=gemini
GOOGLE_AI_API_KEY=your-gemini-api-key
# LLM_MODEL_FAST=gemini-3.1-flash-lite-preview (Recommend — fast & cheap)
LLM_MODEL_FAST=gemini-2.5-flash

# Thinking level for Gemini 3.x+: "minimal" | "low" | "medium" | "high"
# Gemini 2.5 uses thinking_budget_tokens automatically (this setting is ignored)
LLM_THINKING_LEVEL=medium

# Max output tokens for chat (includes thinking tokens)
# Gemini 2.5 Flash: up to 8192, Gemini 3.1 Flash-Lite: up to 65536
LLM_MAX_OUTPUT_TOKENS=8192

# --- Ollama (inactive — uncomment để dùng, comment Gemini ở trên) ---
# LLM_PROVIDER=ollama
# OLLAMA_HOST=http://localhost:11434
# Multimodal (Recommend)
# OLLAMA_MODEL=qwen3.5:9b
# OLLAMA_MODEL=qwen3.5:4b
# OLLAMA_MODEL=gemma3:12b
# Text only model
# OLLAMA_MODEL=kamekichi128/qwen3-4b-instruct-2507
# Enable thinking mode for Ollama (default: false — reduces latency for thinking models like qwen3.5)
# OLLAMA_ENABLE_THINKING=false

# ===========================================
# KG Embedding (có thể khác LLM provider)
# ===========================================

# --- KG Embedding: Gemini (active) ---
KG_EMBEDDING_PROVIDER=gemini
KG_EMBEDDING_MODEL=gemini-embedding-001
KG_EMBEDDING_DIMENSION=3072

# --- KG Embedding: Ollama (inactive) ---
# KG_EMBEDDING_PROVIDER=ollama
# KG_EMBEDDING_MODEL=bge-m3
# KG_EMBEDDING_DIMENSION=1024

# --- KG Embedding: Sentence-Transformers (inactive — fully local, no API needed) ---
# KG_EMBEDDING_PROVIDER=sentence_transformers
# KG_EMBEDDING_MODEL=BAAI/bge-m3
# KG_EMBEDDING_DIMENSION=1024

# OmilosRAG Pipeline (all optional, defaults shown)
OMILOSRAG_ENABLED=true
OMILOSRAG_ENABLE_KG=true
# Global default KG language (can be overridden per workspace in UI)
OMILOSRAG_KG_LANGUAGE=English
OMILOSRAG_KG_ENTITY_TYPES=["Organization","Person","Product","Location","Event","Financial_Metric","Technology","Date","Regulation"]
# Document Parser: "docling" (default, heavy GPU) or "marker" (lighter ~2-4GB, better math/LaTeX)
# OMILOSRAG_DOCUMENT_PARSER=docling
# OMILOSRAG_MARKER_USE_LLM=false

OMILOSRAG_ENABLE_IMAGE_EXTRACTION=true
OMILOSRAG_ENABLE_IMAGE_CAPTIONING=true
OMILOSRAG_EMBEDDING_MODEL=BAAI/bge-m3
OMILOSRAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
OMILOSRAG_CHUNK_MAX_TOKENS=512
OMILOSRAG_VECTOR_PREFETCH=20
OMILOSRAG_RERANKER_TOP_K=8
OMILOSRAG_MIN_RELEVANCE_SCORE=0.15

# Processing timeout — stale documents auto-recover to FAILED after this many minutes
# OMILOSRAG_PROCESSING_TIMEOUT_MINUTES=10

# Pre-ingestion Deduplication (noise filter + content-hash + near-duplicate)
OMILOSRAG_DEDUP_ENABLED=true
OMILOSRAG_DEDUP_MIN_CHUNK_LENGTH=50
OMILOSRAG_DEDUP_NEAR_THRESHOLD=0.85

# Neo4j Graph Database (for Knowledge Graph storage)
# Graph Storage: "NetworkXStorage" (file-based, default) | "Neo4JStorage" (scalable)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=Smile@123
NEO4J_DATABASE=neo4j
OMILOSRAG_KG_GRAPH_STORAGE=Neo4JStorage

# CORS
CORS_ORIGINS=["http://localhost:5174","http://localhost:3000"]
